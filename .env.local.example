# ─── Supabase (reuse the existing project; create the studio_* tables via supabase/migrations/001_studio_schema.sql) ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Anthropic (receipt OCR via Claude vision; cheaper than Mindee for low volume) ───
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Resend (invoice email) ───
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Studio <faktura@nordbok.app>

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ─── Cron auth (set this on Vercel; it must match the value Vercel sends in Authorization header for crons) ───
CRON_SECRET=change-me-to-a-random-string

# ─── Web Push (generate with: npx web-push generate-vapid-keys) ───
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@hopkinsmethod.com
